    "android-release": "expo run:android --variant release",
    "dev": "expo start",
    "eas:android-local": "eas build -p android --local",
    "eas:android-preview": "eas build -p android --profile preview",
    "eas:android-production": "eas build -p android --profile production",
    "eas:ios-local": "eas build -p ios --local",
    "eas:ios-preview": "eas build -p ios --profile preview",
    "eas:ios-production": "eas build -p ios --profile production",
    "ios": "expo run:ios",
    "ios-release": "expo run:ios --configuration Release",
    "pre": "expo prebuild"
  },
  "dependencies": {
    "@babel/runtime": "^7.26.9",
    "@expo/vector-icons": "^14.0.2",
    "@react-navigation/bottom-tabs": "^7.2.0",
    "@react-navigation/native": "^7.0.14",
    "babel-preset-expo": "^12.0.9",
    "expo": "~52.0.37",
    "expo-asset": "^11.0.4",
    "expo-blur": "~14.0.3",
    "expo-constants": "~17.0.7",
    "expo-font": "~13.0.4",
    "expo-haptics": "~14.0.1",
    "expo-linking": "~7.0.5",
    "expo-modules-autolinking": "*",
    "expo-router": "~4.0.17",
    "expo-splash-screen": "~0.29.22",
    "expo-status-bar": "~2.0.1",
    "expo-symbols": "~0.2.2",
    "expo-system-ui": "~4.0.8",
    "expo-web-browser": "~14.0.2",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-native": "0.76.7",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-reanimated": "~3.16.1",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-web": "~0.19.13",
    "react-native-webview": "13.12.5"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@expo-webview-kit/typescript-config": "workspace:*",
    "@types/react": "catalog:",
    "typescript": "catalog:"
